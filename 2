using UnityEditor.Experimental.GraphView;
using UnityEngine;
using UnityEngine.LowLevelPhysics2D;

public class GameManager : MonoBehaviour
{
    bool novato = true;
    bool intermedio = true;
    bool avanzado = true;
    bool elite = true;
    int puntaje = 1-600; 




    // Start is called once before the first execution of Update after the MonoBehaviour is created
    // ejercicio del 1 al 15
    void Start()
    {
        if (puntaje <= 100) novato = true;
        if (puntaje <= 300) intermedio = true;
        if (puntaje <= 600) avanzado = true;
        if(puntaje >= 600) elite = true;



    }

    // Update is called once per frame
    void Update()
    {
        
    }
}
